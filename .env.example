# Configurações do Servidor
PORT=5000

# Credenciais do Jira
JIRA_API_URL=https://sua-empresa.atlassian.net
JIRA_USER_EMAIL=seu-email@empresa.com
JIRA_PAT=seu-jira-personal-access-token

# Credenciais do Azure DevOps
AZURE_API_URL=https://dev.azure.com/sua-organizacao/seu-projeto
AZURE_PAT=seu-azure-personal-access-token

# Configurações de SSL (para ambientes corporativos com proxy/certificado próprio)
SSL_VERIFY=False

# Chave de API do Google Gemini
GEMINI_API_KEY=sua-chave-de-api-gemini

